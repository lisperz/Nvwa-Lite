# Local Development Environment Variables
# Copy this to .env for local testing

# OpenAI API Key
OPENAI_API_KEY=your-openai-key-here

# Redis Configuration (Docker Compose will start Redis)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# S3 Configuration (Optional - will use local storage fallback if omitted)
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_DEFAULT_REGION=us-east-1
# S3_BUCKET_NAME=nvwa-test-local

# Test Pilot Tokens (generated by scripts/generate_pilot_tokens.sh)
# Replace these with actual tokens after running the script
PILOT_TOKEN_1=test_token_user1_local
PILOT_TOKEN_2=test_token_user2_local
PILOT_TOKEN_3=test_token_user3_local

# Session Configuration
MAX_CONCURRENT_SESSIONS=2
SESSION_TIMEOUT_MINUTES=30

# Logging
LOG_LEVEL=INFO
