# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-key-here

# AWS S3 Configuration (required for Phase 1)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-west-2
S3_BUCKET_NAME=nvwa-mvp-pilot

# Redis Configuration (optional - will use in-memory fallback if not available)
REDIS_HOST=localhost
REDIS_PORT=6379

# Pilot User Tokens (add from pilot_tokens.env after running scripts/generate_pilot_tokens.sh)
# Format: PILOT_TOKEN_XXX=user_id:email:token
# PILOT_TOKEN_001=beta_user_001:user1@example.com:TOKEN_HERE
# PILOT_TOKEN_002=beta_user_002:user2@example.com:TOKEN_HERE
# ... (add all 10 pilot users)
